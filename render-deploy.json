{
  "$schema": "https://docs.render.com/render-deploy/schema",
  "services": [
    {
      "type": "web",
      "name": "mmm-api",
      "plan": "free",
      "runtime": "node",
      "buildCommand": "cd server && npm ci && npm run build",
      "startCommand": "cd server && node dist/server.js",
      "envVars": [
        {
          "key": "NODE_ENV",
          "value": "production"
        },
        {
          "key": "PORT",
          "value": "4000"
        },
        {
          "key": "JWT_SECRET",
          "generateValue": true
        },
        {
          "key": "REFRESH_SECRET",
          "generateValue": true
        },
        {
          "key": "DATABASE_URL"
        },
        {
          "key": "REDIS_URL"
        }
      ]
    }
  ]
}
