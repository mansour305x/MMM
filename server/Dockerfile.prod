# صورة Dockerfile للتشغيل على Render
FROM node:22-alpine

WORKDIR /app

# نسخ ملفات المشروع
COPY package*.json ./
COPY server/ ./server/
COPY db/ ./db/

# تثبيت الاعتمادات وبناء
WORKDIR /app/server
RUN npm ci --only=production && npm run build

# تشغيل الخادم
ENV NODE_ENV=production
EXPOSE 4000

CMD ["node", "dist/server.js"]
