NODE_ENV=development
PORT=4000
HOST=0.0.0.0
JWT_SECRET=change_me_to_strong_secret
JWT_EXPIRES_IN=15m
REFRESH_SECRET=change_me_to_strong_refresh_secret
REFRESH_EXPIRES_IN=30d
DATABASE_URL=postgresql://mmm:mmm@localhost:5432/mmm
REDIS_URL=redis://localhost:6379
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
SMS_PROVIDER=mock
SMS_SENDER_ID=MMM
SMS_API_KEY=replace_with_sms_api_key
SMS_API_SECRET=replace_with_sms_api_secret
SMS_BASE_URL=https://sms.example.com/api

MAIL_PROVIDER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=mailer@example.com
MAIL_PASSWORD=replace_with_mail_password
MAIL_FROM_NAME=MMM Platform
MAIL_FROM_ADDRESS=no-reply@mmm.com

STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

APP_ENCRYPTION_KEY=replace_with_32_chars_min
WEBHOOK_SECRET=replace_with_webhook_secret
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute
CORS_ORIGIN=http://localhost:5173
